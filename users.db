# ============ STATS COMMAND (For Admin) ============
@bot.message_handler(commands=['stats'])
def stats(message):
    # Optional: Replace 'YOUR_USER_ID' with your actual Telegram ID so only you can see this
    count = get_user_count()
    bot.reply_to(message, f"📊 **Total Bot Users:** {count}")
